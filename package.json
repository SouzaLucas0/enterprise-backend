{
  "name": "enterprise-api",
  "version": "1.0.0",
  "author": "github.com/SouzaLucas0",
  "dependencies": {
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "eventsource": "^4.1.0",
    "node-firebird": "^1.1.9",
    "pg": "^8.18.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "swagger-ui-dist": "^5.31.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27"
  },
  "scripts": {
    "typeorm": "typeorm-ts-node-commonjs -d data-source.ts",
    "migrate-data": "ts-node scripts/migrate-data.ts",
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "bin": "dist/main.js",
  "pkg": {
    "assets": [
      "dist/**/*.js",
      "node_modules/@nestjs/common/**/*.js",
      "node_modules/@nestjs/core/**/*.js",
      "node_modules/@nestjs/platform-express/**/*.js",
      "node_modules/typeorm/**/*.js",
      "node_modules/pg/**/*",
      "node_modules/node-firebird/**/*",
      "node_modules/swagger-ui-dist/**/*",
      "node_modules/ansis/**/*"
    ],
    "scripts": [
      "dist/**/*.js"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "compress": "Brotli"
  }
}
